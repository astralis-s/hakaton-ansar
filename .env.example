# Copy to .env for local development (`make run`). Compose injects its own values.

# --- App ---
APP_ENV=development
MIGRATE_ON_BOOT=true

# --- HTTP ---
HTTP_PORT=8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_SHUTDOWN_TIMEOUT=10s
# Comma-separated origins allowed by CORS (the SPA dev server).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database ---
# For `make run` against a local/compose postgres exposed on 5432:
DATABASE_URL=postgres://amana:amana@localhost:5432/amana?sslmode=disable
DATABASE_MAX_CONNS=10

# --- Auth (internal /api/app) ---
JWT_SECRET=dev-secret-change-me
JWT_TTL=24h

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=json

# --- Financing (murabaha) ---
# Illustrative annual rate for the "no-riba vs conventional credit" comparison.
FINANCING_COMPARISON_RATE_PERCENT=28

# --- Prayer times (namaz scheduler; defaults: Grozny, Shafi'i) ---
PRAYER_LAT=43.3178
PRAYER_LON=45.6949
PRAYER_MADHAB=shafii
PRAYER_TIMEZONE=Europe/Moscow
PRAYER_METHOD=MWL
PRAYER_BUFFER_BEFORE_MIN=0
PRAYER_BUFFER_AFTER_MIN=20
PRAYER_JUMMAH_START=12:30
PRAYER_JUMMAH_END=14:00
