# Токен бота, выданный @BotFather (обязательно).
BOT_TOKEN=123456:ABC-DEF...

# Адрес, на котором поднимается веб-инбокс менеджера.
HTTP_ADDR=:8090

# Пароль для входа менеджера в веб-инбокс.
# Если оставить пустым — вход без пароля (удобно для локальной демки).
MANAGER_PASSWORD=changeme

# Файл, в котором бот хранит пользователей и переписку (JSON).
DATA_FILE=data/bot-data.json

# Таймаут long polling Telegram getUpdates (секунды).
POLL_TIMEOUT_SEC=30
